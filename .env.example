# AI Platform 统一环境变量示例
# 复制为 .env 后按环境填写，切勿提交真实密钥

# ========== Runtime ==========
NODE_ENV=production
LOG_LEVEL=info

# ========== Core Ports ==========
ADMIN_UI_PORT=3000
AI_GATEWAY_PORT=3001
CONTROL_PLANE_PORT=3104
KNOWLEDGE_BASE_PORT=8000

# ========== Database ==========
DB_HOST=rm-bp17ns75mi339poo5fo.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_NAME=aiplan_erp_test
DB_USER=erp_test
DB_PASS=change-me

# ========== LLM Provider Keys ==========
DEEPSEEK_API_KEY=sk-xxx
DASHSCOPE_API_KEY=sk-xxx
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# ========== Knowledge Base / Vector Store ==========
# 可选: qdrant | dashvector | memory
VECTOR_STORE_PROVIDER=dashvector

# Qdrant 模式
# QDRANT_URL=http://127.0.0.1:6333

# DashVector 模式
DASHVECTOR_ENDPOINT=https://your-cluster-endpoint.dashvector.cn-hangzhou.aliyuncs.com
DASHVECTOR_API_KEY=sk-xxx
DASHVECTOR_PARTITION=default
DASHVECTOR_TIMEOUT_MS=30000
DASHVECTOR_COLLECTION_READY_TIMEOUT_MS=20000
DASHVECTOR_MAX_UPSERT_BYTES=1800000

# 固定 collection 策略
# DashVector 受 collection 数量限制，生产环境建议长期复用固定 collection
KNOWLEDGE_BASE_COLLECTION=phase1_knowledge_assets
DEEPWIKI_KNOWLEDGE_COLLECTION=deepwiki_assets
# 验收/验证默认复用 KNOWLEDGE_BASE_COLLECTION，避免额外占用 collection 配额
VERIFY_COLLECTION=phase1_knowledge_assets

# Embedding
EMBED_MODEL=BAAI/bge-m3
# 生产环境建议指向预热后的本地模型目录
EMBED_MODEL_PATH=/app/models/BAAI_bge-m3
# 生产环境建议关闭回退，避免静默降级到 hash embedding
ALLOW_FALLBACK_EMBEDDING=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3
DEEPWIKI_QUERY_MAX_COMMUNITIES=3

# ========== URLs ==========
KNOWLEDGE_BASE_INGEST_URL=http://127.0.0.1:8000/api/v1/ingest
KNOWLEDGE_BASE_SEARCH_URL=http://127.0.0.1:8000/api/v1/search
CONTROL_PLANE_RAG_LOG_URL=http://127.0.0.1:3104/api/v1/knowledge/rag-queries
