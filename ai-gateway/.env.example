# AI Gateway 环境变量配置示例
# ⚠️ 重要：复制此文件为 .env 并填写实际值

# ========== 服务配置 ==========
NODE_ENV=development
PORT=3001

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_gateway
DB_USER=root
DB_PASS=password

# ========== LLM Provider API Keys ==========

# 千问 (Qwen) API Key - 阿里云 DashScope
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# OpenAI API Key (可选)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (可选)
# ANTHROPIC_API_KEY=sk-your-anthropic-api-key-here

# ========== 通知系统配置 ==========

# 飞书机器人 Webhook URL
# 获取方式：在飞书群中添加机器人，获取Webhook地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token

# 邮件通知配置 (可选)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ALERT_EMAILS=admin@example.com,team@example.com

# ========== 预算和限流配置 ==========

# 预算告警级别 (使用比例)
BUDGET_WARNING_THRESHOLD=0.8    # 80%
BUDGET_CRITICAL_THRESHOLD=0.95  # 95%

# 飞书/长会话：关闭小时汇总限流、不因 DB 日配额 429（生产可关）
# GATEWAY_DISABLE_HOURLY_RATELIMIT=true
# GATEWAY_RELAX_DAILY_BUDGET=true
# 限流阈值（Token，可选；不设则代码内已为千万级默认）
# GATEWAY_HOURLY_TOKEN_WARNING=10000000
# GATEWAY_HOURLY_TOKEN_LIMIT=50000000
# GATEWAY_DAILY_TOKEN_WARNING=50000000
# GATEWAY_DAILY_TOKEN_LIMIT=500000000
# 超警示阈值时人工延迟（毫秒，0=不延迟）
# GATEWAY_RATELIMIT_WARNING_DELAY_MS=0

# ========== 日志配置 ==========
LOG_LEVEL=info
LOG_RETENTION_DAYS=30

# ========== 高级功能配置 ==========

# 费用预测算法启用
ENABLE_COST_PREDICTION=true

# 动态配额调整启用
ENABLE_DYNAMIC_QUOTA=false

# 自动报告生成
ENABLE_AUTO_REPORTS=true
REPORT_SCHEDULE=daily  # daily, weekly, monthly

# ========== 门禁：POST /api/v1/gates/evaluate（阶段 C）==========
# 指向规划仓库 hermes-web-chat/gate-enforcement-cli.js 的绝对路径；未设置时 evaluate 返回 501
# GATE_ENFORCEMENT_CLI=/path/to/hermes-web-chat/gate-enforcement-cli.js
# 评判子进程调用网关 /v1/chat/completions 时使用的 Key（与 gateway_api_keys 发放值一致）
# AI_GATEWAY_API_KEY=